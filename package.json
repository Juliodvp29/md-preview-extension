{
  "name": "md-preview-extension",
  "displayName": "MD Preview",
  "description": "Markdown preview rendered like GitHub, side by side with your editor",
  "version": "0.1.0",
  "publisher": "juliotero",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/tu-usuario/md-preview-extension"
  },
  "categories": [
    "Formatters",
    "Other"
  ],
  "engines": {
    "vscode": "^1.60.0"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "md-preview-extension.openPreview",
        "title": "Abrir Preview Markdown"
      }
    ],
    "keybindings": [
      {
        "command": "md-preview-extension.openPreview",
        "key": "ctrl+shift+m",
        "when": "editorLangId == markdown"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "marked": "^15.0.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0"
  }
}